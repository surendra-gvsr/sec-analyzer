# ─── SEC Analyzer Environment Configuration ──────────────────────────────────

# LlamaParse Cloud API (required for structure-aware PDF/HTML parsing)
# Get your free key at: https://cloud.llamaindex.ai/
LLAMA_CLOUD_API_KEY=your_llama_cloud_api_key_here

# Groq API (LLM for entity extraction + query synthesis)
# Get your free key at: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-8b-8192

# SEC EDGAR User-Agent (SEC requires a valid email — use a real one)
SEC_USER_EMAIL=yourname@example.com
SEC_COMPANY_NAME=MyPortfolioProject

# Target companies and years (comma-separated)
TARGET_TICKERS=AAPL,MSFT
TARGET_YEARS=2021,2022,2023,2024

# Data storage paths (relative to project root)
RAW_FILINGS_DIR=data/raw_filings
PARSED_MARKDOWN_DIR=data/parsed_markdown
GRAPH_STORE_DIR=data/graph_store
CHROMA_DB_DIR=data/chroma_db

# Application
ENVIRONMENT=development
LOG_LEVEL=INFO
